// Albazourieh — Post-War Damage Assessment & Recovery Platform
// Database: Supabase (PostgreSQL) via Prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────── Enums ───────────────────────────────

enum PropertyType {
  // Consolidated categories used by the current two-card wizard.
  BUILDING
  VEHICLE
  // Legacy values kept so historical rows remain readable.
  HOUSE
  APARTMENT
  LAND
  SHOP
  CAR
  MOTORCYCLE
}

enum OwnershipStatus {
  OWNER
  TENANT
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  APPROVED
  REJECTED
}

enum DamageSeverity {
  TOTAL
  PARTIAL
  MINOR
}

/// Two-tier hierarchy: SUPER_ADMIN (Mas2ool El Baladye — owns staff
/// management) and STAFF_MEMBER (auditors / field inspectors).
enum MunicipalityRole {
  SUPER_ADMIN
  STAFF_MEMBER
}

enum AttachmentType {
  PHOTO
  DOCUMENT
}

/// Simple intake triage for displaced-person registrations (both the
/// Syrian and Lebanese programmes share the same three-state lifecycle).
enum DisplacedStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Where a displaced Syrian household currently lives.
enum ShelterType {
  RENTED_APARTMENT
  HOSTED_WITH_FAMILY
  COLLECTIVE_SHELTER
  TENT_OR_CAMP
  OTHER
}

enum Language {
  AR
  EN
}

// ─────────────────────────────── Models ──────────────────────────────

/// Citizen account. Authentication is phone-number based (OTP-ready):
/// the otpCode/otpExpiresAt pair backs a one-time-password login flow.
model User {
  id                String    @id @default(uuid()) @db.Uuid
  phoneNumber       String    @unique @db.VarChar(20)
  fullName          String    @db.VarChar(120)
  preferredLanguage Language  @default(AR)
  isPhoneVerified   Boolean   @default(false)
  otpCode           String?   @db.VarChar(10)
  otpExpiresAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  properties Property[]
  reports    DamageReport[]

  @@map("users")
}

/// The damaged asset. Coordinates are captured on the citizen's phone
/// via the HTML5 Geolocation API and are critical for field inspection.
model Property {
  id                   String           @id @default(uuid()) @db.Uuid
  type                 PropertyType
  ownershipStatus      OwnershipStatus?
  realEstateNumber     String?          @db.VarChar(60)
  /// Vehicle sub-type for VEHICLE reports: CAR/TRUCK/TRACTOR/BUS/VAN/OTHER.
  vehicleType          String?          @db.VarChar(30)
  /// Free-text description when vehicleType is OTHER.
  vehicleTypeOther     String?          @db.VarChar(120)
  /// Tenant submissions may share the landlord's phone (optional).
  ownerPhoneNumber     String?          @db.VarChar(20)
  district             String?          @db.VarChar(120)
  /// Kept in sync with `street` so dashboard filters/map keep working.
  neighborhood         String           @db.VarChar(120)
  // v2 deep-precision location fields.
  street               String?          @db.VarChar(120)
  projectName          String?          @db.VarChar(120)
  floor                String?          @db.VarChar(30)
  /// Unit area in square metres — mandatory for HOUSE/SHOP/APARTMENT.
  unitArea             Int?
  additionalDirections String?          @db.VarChar(255)
  addressLine          String?          @db.VarChar(255)
  latitude             Float
  longitude            Float
  ownerId              String           @db.Uuid
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  owner   User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  reports DamageReport[]

  @@index([district])
  @@index([neighborhood])
  @@index([latitude, longitude])
  @@index([realEstateNumber])
  @@map("properties")
}

/// One damage claim filed by a citizen.
model DamageReport {
  id              String         @id @default(uuid()) @db.Uuid
  /// Public 6-character reference (uppercase letters + digits, e.g.
  /// "A4X8Q2") — the identifier shown to citizens and staff.
  referenceCode   String         @unique @db.VarChar(6)
  description     String
  status          ReportStatus   @default(PENDING)
  severity        DamageSeverity
  rejectionReason String?
  rejectedField   String?        @db.VarChar(100)
  reporterId      String         @db.Uuid
  propertyId      String         @db.Uuid
  reviewedById    String?        @db.Uuid
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  reporter       User              @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  property       Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reviewedBy     MunicipalityUser? @relation(fields: [reviewedById], references: [id], onDelete: SetNull)
  attachments    Attachment[]
  inspectionLogs InspectionLog[]

  @@index([status])
  @@index([severity])
  @@index([status, severity])
  @@index([createdAt])
  @@map("damage_reports")
}

/// Uploaded proof: photos of the damage or ownership documents.
model Attachment {
  id        String         @id @default(uuid()) @db.Uuid
  url       String         @db.VarChar(2048)
  type      AttachmentType
  /// What the file proves: DAMAGE_PHOTO, NATIONAL_ID, PROPERTY_DEED,
  /// RENTAL_CONTRACT, VEHICLE_REGISTRATION, RESIDENCY_PROOF
  label     String?        @db.VarChar(60)
  mimeType  String?        @db.VarChar(100)
  sizeBytes Int?
  reportId  String         @db.Uuid
  createdAt DateTime       @default(now())

  report DamageReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("attachments")
}

/// Internal municipality staff account.
model MunicipalityUser {
  id               String           @id @default(uuid()) @db.Uuid
  email            String           @unique @db.VarChar(255)
  passwordHash     String           @db.VarChar(255)
  fullName         String           @db.VarChar(120)
  role             MunicipalityRole @default(STAFF_MEMBER)
  municipalityName String           @db.VarChar(120)
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  reviewedReports DamageReport[]
  inspectionLogs  InspectionLog[]
  auditLogs       AuditLog[]

  @@map("municipality_users")
}

/// "تتبع العمليات" — immutable trail of every administrative mutation:
/// who did what, to which record, from where, and when.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  adminId    String   @db.Uuid
  /// Cached so the trail renders without joins and survives staff renames.
  adminName  String   @db.VarChar(120)
  /// CREATE_STAFF | DELETE_STAFF | UPDATE_REPORT_STATUS | EXPORT_DATA
  actionType String   @db.VarChar(40)
  targetId   String   @db.VarChar(60)
  details    String
  /// Arabic counterpart of `details` for dual-language audit rendering.
  detailsAr  String?
  ipAddress  String?  @db.VarChar(45)
  createdAt  DateTime @default(now())

  admin MunicipalityUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([adminId])
  @@map("audit_logs")
}

/// One registered Syrian displaced household ("لاجئين"). Deliberately
/// standalone — never joined with Lebanese registrations or damage
/// reports so each programme's analytics stay isolated.
model SyrianDisplaced {
  id                 String          @id @default(uuid()) @db.Uuid
  fullName           String          @db.VarChar(120)
  phone              String          @db.VarChar(20)
  familyMembersCount Int
  /// Full names of all family members.
  familyMembersNames String          @default("") @db.VarChar(1000)
  /// City/town of origin in Syria.
  originalCity       String          @db.VarChar(120)
  /// UNHCR / government registration number — absent when unregistered.
  registrationNumber String?         @db.VarChar(60)
  shelterType        ShelterType
  /// Identity document(s) (ID card / passport photo or PDF) proving who
  /// is registering — streamed to Supabase Storage, URLs kept here.
  idDocumentUrls     String[]        @default([])
  /// Selected urgent needs (FOOD/MEDICAL/SHELTER/CASH), possibly empty.
  urgentNeeds        String[]
  /// Date the household entered Lebanon.
  entryDate          DateTime        @db.Date
  status             DisplacedStatus @default(PENDING)
  createdAt          DateTime        @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("syrian_displaced")
}

/// One registered internally-displaced Lebanese household ("نازحين").
model LebaneseDisplaced {
  id                    String          @id @default(uuid()) @db.Uuid
  fullName              String          @db.VarChar(120)
  phone                 String          @db.VarChar(20)
  familyMembersCount    Int
  /// Full names of all family members.
  familyMembersNames    String          @default("") @db.VarChar(1000)
  /// Village of origin in Lebanon the household was displaced from.
  originVillage         String          @db.VarChar(120)
  isPropertyDamaged     Boolean         @default(false)
  primarySourceOfIncome String?         @db.VarChar(120)
  /// Identity document(s) (ID card / passport photo or PDF) proving who
  /// is registering — streamed to Supabase Storage, URLs kept here.
  idDocumentUrls        String[]        @default([])
  /// Selected urgent needs (FOOD/MEDICAL/SHELTER/CASH), possibly empty.
  urgentNeeds           String[]
  /// Date the household was displaced from its village.
  displacementDate      DateTime        @db.Date
  status                DisplacedStatus @default(PENDING)
  createdAt             DateTime        @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("lebanese_displaced")
}

/// Audit trail of official engineer field visits.
model InspectionLog {
  id                String         @id @default(uuid()) @db.Uuid
  reportId          String         @db.Uuid
  inspectorId       String         @db.Uuid
  visitDate         DateTime
  structuralNotes   String
  estimatedCostUsd  Decimal        @db.Decimal(12, 2)
  confirmedSeverity DamageSeverity
  createdAt         DateTime       @default(now())

  report    DamageReport     @relation(fields: [reportId], references: [id], onDelete: Cascade)
  inspector MunicipalityUser @relation(fields: [inspectorId], references: [id], onDelete: Restrict)

  @@index([reportId])
  @@map("inspection_logs")
}
