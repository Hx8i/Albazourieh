# Supabase PostgreSQL — pooled connection (PgBouncer, transaction mode,
# port 6543). connection_limit=1 is required when Prisma sits behind a
# transaction-mode pooler; connect_timeout/pool_timeout are raised for
# high-latency links.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&connect_timeout=60&pool_timeout=60"
# Session-mode connection (port 5432) used by Prisma Migrate.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?connect_timeout=60"

PORT=4000
CORS_ORIGIN=http://localhost:3000

# Signs municipality staff JWTs (12h expiry). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<random-hex-string>

# First staff account created by `pnpm run seed`.
SEED_ADMIN_EMAIL=admin@bazourieh.gov.lb
SEED_ADMIN_PASSWORD=<min-8-chars>

# Supabase Storage (server-side only — never exposed to the browser).
# SUPABASE_SERVICE_ROLE_KEY: Supabase Dashboard -> Settings -> API -> service_role secret.
# Buckets damage-photos (5MB images) and voice-notes (10MB audio) are
# created automatically on boot. Leave the key unset and uploads fail
# gracefully (503) without blocking report submission.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
